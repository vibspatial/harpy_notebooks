{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: pytest",
            "type": "debugpy",
            "request": "launch",
            "pythonArgs": ["-Xfrozen_modules=off"], // <- key line
            "console": "integratedTerminal",
            "justMyCode": false,
            "program":"${file}",
            "purpose":["debug-test"],
            "cwd": "${workspaceFolder}",
            "env": {"PYTHONIOENCODING": "utf-8;"},
            "presentation": {
                "group": "pytest"
            }
        }
    ]
}
